#include <stdio.h>

struct Process
{
    int pid;
    int at;
    int bt;
    int rt;
    int ct;
    int tat;
    int wt;
    int completed;
};

int main()
{
    struct Process p[50];
    int n, i, choice;
    int time = 0, done = 0;
    float avgWT = 0, avgTAT = 0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        p[i].pid = i+1;
        printf("Enter AT and BT for P%d: ",i+1);
        scanf("%d %d",&p[i].at,&p[i].bt);

        p[i].rt = p[i].bt;
        p[i].completed = 0;
    }

    printf("\n1. Non Preemptive SJF");
    printf("\n2. Preemptive SRTF");
    printf("\nEnter choice: ");
    scanf("%d",&choice);

    if(choice==1)
    {


        while(done<n)
        {
            int minBT = 9999;
            int index = -1;

            for(i=0;i<n;i++)
            {
                if(p[i].at<=time && p[i].completed==0)
                {
                    if(p[i].bt < minBT)
                    {
                        minBT = p[i].bt;
                        index = i;
                    }
                }
            }

            if(index==-1)
            time++;

            else
            {
                time += p[index].bt;

                p[index].ct = time;
                p[index].tat = p[index].ct - p[index].at;
                p[index].wt = p[index].tat - p[index].bt;

                p[index].completed = 1;
                done++;
            }
        }
    }

    else if(choice==2)
    {


        while(done<n)
        {
            int minRT = 9999;
            int index = -1;

            for(i=0;i<n;i++)
            {
                if(p[i].at<=time && p[i].completed==0)
                {
                    if(p[i].rt < minRT && p[i].rt>0)
                    {
                        minRT = p[i].rt;
                        index = i;
                    }
                }
            }

            if(index==-1)
            time++;

            else
            {
                p[index].rt--;
                time++;

                if(p[index].rt==0)
                {
                    p[index].ct = time;
                    p[index].tat = p[index].ct - p[index].at;
                    p[index].wt = p[index].tat - p[index].bt;

                    p[index].completed = 1;
                    done++;
                }
            }
        }
    }

    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\n");

    for(i=0;i<n;i++)
    {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
        p[i].pid,p[i].at,p[i].bt,p[i].ct,p[i].tat,p[i].wt);

        avgWT += p[i].wt;
        avgTAT += p[i].tat;
    }

    printf("\nAverage WT = %.2f",avgWT/n);
    printf("\nAverage TAT = %.2f",avgTAT/n);

}
